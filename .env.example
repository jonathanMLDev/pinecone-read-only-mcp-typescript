# Pinecone Read-Only MCP Configuration
# Generic onboarding: see examples/quickstart/.env.example and examples/quickstart/README.md

# Required: Your Pinecone API key
PINECONE_API_KEY=your-pinecone-api-key-here

# Required: Dense (hybrid) Pinecone index name
PINECONE_INDEX_NAME=your-index-name

# Optional: Reranking model (omit to disable rerank in core; Alliance CLI defaults when unset — see docs/CONFIGURATION.md)
# PINECONE_RERANK_MODEL=your-rerank-model

# Optional: Default number of results to return (default: 10)
PINECONE_TOP_K=10

# Optional: Logging level (default: INFO)
# Options: DEBUG, INFO, WARN, ERROR
PINECONE_READ_ONLY_MCP_LOG_LEVEL=INFO

# Optional: Logging format (default: text)
# Options: text, json
PINECONE_READ_ONLY_MCP_LOG_FORMAT=text

# Optional: Sparse index name (default: ${PINECONE_INDEX_NAME}-sparse)
# PINECONE_SPARSE_INDEX_NAME=my-index-sparse

# Optional: Namespace + suggestion-flow cache TTL in seconds (default: 1800 = 30min)
# PINECONE_CACHE_TTL_SECONDS=1800

# Optional: Suggest-flow gate (PINECONE_DISABLE_SUGGEST_FLOW).
# Core resolveConfig default: true (gate off). Alliance CLI default: false (gate on).
# PINECONE_DISABLE_SUGGEST_FLOW=false

# Optional: Request timeout for Pinecone calls, in milliseconds (default: 15000)
# PINECONE_REQUEST_TIMEOUT_MS=15000
